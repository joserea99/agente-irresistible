# Google Gemini API Key (REQUIRED)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_key_here

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Frontend Supabase (for Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe (REQUIRED for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PRICE_ID=price_your_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Auth
SECRET_KEY=generate_with_python_c_import_secrets_print_secrets_token_urlsafe_32

# CORS - comma-separated origins (OPTIONAL, has defaults)
# ALLOWED_ORIGINS=http://localhost:3000,https://www.irresistibleagent.com

# Brandfolder (OPTIONAL - for Smart Learning)
# BRANDFOLDER_API_KEY=your_brandfolder_key

# Migration endpoint secret (OPTIONAL)
# MIGRATION_SECRET=your_migration_secret

# AI Model Config (OPTIONAL - has defaults)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_TEMPERATURE=0.7

# Rate Limiting (OPTIONAL - has defaults)
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_MAGIC=10/minute
